import re

# Suspicious phishing keywords
phishing_keywords = [
    "urgent",
    "verify your account",
    "click here",
    "password",
    "login",
    "bank",
    "confirm",
    "winner",
    "prize",
    "free",
    "security alert",
    "update account",
    "suspended"
]

# Suspicious URL patterns
suspicious_domains = [
    "bit.ly",
    "tinyurl.com",
    "login-verify",
    "secure-update",
    "account-check"
]


def analyze_message(message):
    red_flags = []
    risk_score = 0

    text = message.lower()

    # Check keywords
    for keyword in phishing_keywords:
        if keyword in text:
            red_flags.append(
                f"Suspicious keyword found: '{keyword}'"
            )
            risk_score += 10

    # Find links
    links = re.findall(
        r'https?://[^\s]+',
        message
    )

    if links:
        for link in links:
            red_flags.append(
                f"Suspicious link detected: {link}"
            )
            risk_score += 20

            for domain in suspicious_domains:
                if domain in link:
                    red_flags.append(
                        f"Known suspicious domain: {domain}"
                    )
                    risk_score += 20

    # Check urgency
    if "immediately" in text or "within 24 hours" in text:
        red_flags.append(
            "Creates urgency or pressure to act quickly"
        )
        risk_score += 15

    # Final report
    print("\n====== Phishing Awareness Report ======")

    if red_flags:
        print("\nRed Flags Found:")
        for flag in red_flags:
            print("- " + flag)

        print("\nRisk Score:", risk_score, "/100")

        print(
            "\nWhy this message is unsafe:"
        )
        print(
            "The message contains indicators commonly "
            "used in phishing attacks such as suspicious "
            "links, requests for sensitive information, "
            "or urgent language."
        )

    else:
        print(
            "No major phishing indicators detected."
        )


# Main program

print("Phishing Awareness Analysis Tool")
print("--------------------------------")

email = input(
    "\nPaste email/message text:\n"
)

analyze_message(email)